# Copie este arquivo para .env em desenvolvimento local.
# Em produção (Render), essas variáveis são definidas no painel do Render, não em arquivo.

PORT=8080
NODE_ENV=development

# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-por-um-valor-aleatorio-longo

# Usuário do painel
ADMIN_USER=admin

# Gere com: node hash-password.js "sua-senha-aqui"
ADMIN_PASSWORD_HASH=

# String de conexão do MongoDB Atlas (pegue no painel do Atlas em "Connect")
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/proxima-parada

# Credenciais do Cloudinary (pegue no dashboard do Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
